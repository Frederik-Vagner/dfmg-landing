    <!-- Hero — outcome-driven, not feature-driven -->
    <section class="platform-hero">
        <div class="container">
            <div class="subtitle" style="color: rgba(255,255,255,0.6);">{{ t.hero.subtitle }}</div>
            <div class="title">{{ t.hero.title }}</div>
            <p class="body">{{ t.hero.body }}</p>
            <div class="hero-actions">
                <a href="{{ prefix }}/demo.html" class="btn btn--success btn--md"><iconify-icon icon="fluent:play-circle-20-filled" inline class="mr-05"></iconify-icon> {{ t.hero.cta_demo }}</a>
                <a href="{{ prefix }}/features.html" class="btn btn--ghost btn--md">{{ t.hero.cta_features }}</a>
            </div>

            <!-- TODO: Replace with actual dashboard screenshot or 60s product video -->
            <div class="screenshot-placeholder" style="min-height: 400px; margin-top: 3rem;">
                <div style="text-align: center;">
                    <iconify-icon icon="fluent:play-circle-20-filled" inline style="font-size: 3rem; margin-bottom: 1rem; display: block; opacity: 0.5;"></iconify-icon>
                    <span>{{ t.hero.placeholder_text }}</span><br>
                    <small style="opacity: 0.5;">{{ t.hero.placeholder_hint }}</small>
                </div>
            </div>
        </div>
    </section>

    <!-- Social proof + outcome metrics -->
    <section class="section section--half">
        <div class="container">
            <div class="text-center mb-2">
                <div class="body text-gray">{{ t.proof.text | safe }}</div>
            </div>

            <!-- TODO: Replace with real partner/client logos or integration logos -->
            <div class="flex flex-4 mb-2" style="align-items: center; justify-content: center; opacity: 0.4;">
                <div class="text-center text-gray" style="padding: 1rem;">[Client Logo 1]</div>
                <div class="text-center text-gray" style="padding: 1rem;">[Client Logo 2]</div>
                <div class="text-center text-gray" style="padding: 1rem;">[Client Logo 3]</div>
                <div class="text-center text-gray" style="padding: 1rem;">[Integration Logo]</div>
            </div>

            <div class="flex flex-4">
                <div class="card p-1 bg-gradient-white text-center">
                    <div class="metric-value">{{ t.metrics.saved_value }}</div>
                    <div class="metric-label">{{ t.metrics.saved_label }}</div>
                </div>
                <div class="card p-1 bg-gradient-white text-center">
                    <div class="metric-value">{{ t.metrics.ontime_value }}</div>
                    <div class="metric-label">{{ t.metrics.ontime_label }}</div>
                </div>
                <div class="card p-1 bg-gradient-white text-center">
                    <div class="metric-value">{{ t.metrics.compliance_value }}</div>
                    <div class="metric-label">{{ t.metrics.compliance_label }}</div>
                </div>
                <div class="card p-1 bg-gradient-white text-center">
                    <div class="metric-value">{{ t.metrics.wait_value }}</div>
                    <div class="metric-label">{{ t.metrics.wait_label }}</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Built by practitioners — your differentiator -->
    <section class="section section--light section--half">
        <div class="container">
            <div class="text-center">
                <div class="subtitle text-primary">{{ t.why.subtitle }}</div>
                <div class="title text-charcoal">{{ t.why.title }}</div>
                <div class="body text-gray mb-4">{{ t.why.body }}</div>
            </div>

            <div class="value-grid">
                <div class="value-card">
                    <div class="value-card__icon">
                        <iconify-icon icon="fluent:flag-20-filled" inline></iconify-icon>
                    </div>
                    <div class="value-card__title">{{ t.why.card1_title }}</div>
                    <div class="value-card__desc">{{ t.why.card1_desc }}</div>
                </div>
                <div class="value-card">
                    <div class="value-card__icon">
                        <iconify-icon icon="fluent:cube-multiple-20-filled" inline></iconify-icon>
                    </div>
                    <div class="value-card__title">{{ t.why.card2_title }}</div>
                    <div class="value-card__desc">{{ t.why.card2_desc }}</div>
                </div>
                <div class="value-card">
                    <div class="value-card__icon">
                        <iconify-icon icon="fluent:link-20-filled" inline></iconify-icon>
                    </div>
                    <div class="value-card__title">{{ t.why.card3_title }}</div>
                    <div class="value-card__desc">{{ t.why.card3_desc }}</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Module overview -->
    <section class="section">
        <div class="container">
            <div class="text-center mb-4">
                <div class="subtitle text-primary">{{ t.modules.subtitle }}</div>
                <div class="title text-charcoal">{{ t.modules.title }}</div>
                <div class="body text-gray">{{ t.modules.body }}</div>
            </div>

            <div class="module-grid">
                <a href="{{ prefix }}/features.html#operations" class="module-card">
                    <div class="module-card__icon"><iconify-icon icon="fluent:calendar-checkmark-20-filled" inline></iconify-icon></div>
                    <div class="module-card__title">{{ t.modules.operations_title }}</div>
                    <div class="module-card__desc">{{ t.modules.operations_desc }}</div>
                </a>
                <a href="{{ prefix }}/features.html#clients" class="module-card">
                    <div class="module-card__icon"><iconify-icon icon="fluent:people-20-filled" inline></iconify-icon></div>
                    <div class="module-card__title">{{ t.modules.clients_title }}</div>
                    <div class="module-card__desc">{{ t.modules.clients_desc }}</div>
                </a>
                <a href="{{ prefix }}/features.html#employees" class="module-card">
                    <div class="module-card__icon"><iconify-icon icon="fluent:person-20-filled" inline></iconify-icon></div>
                    <div class="module-card__title">{{ t.modules.employees_title }}</div>
                    <div class="module-card__desc">{{ t.modules.employees_desc }}</div>
                </a>
                <a href="{{ prefix }}/features.html#finance" class="module-card">
                    <div class="module-card__icon"><iconify-icon icon="fluent:calculator-20-filled" inline></iconify-icon></div>
                    <div class="module-card__title">{{ t.modules.finance_title }}</div>
                    <div class="module-card__desc">{{ t.modules.finance_desc }}</div>
                </a>
                <a href="{{ prefix }}/features.html#crm" class="module-card">
                    <div class="module-card__icon"><iconify-icon icon="fluent:mail-read-20-filled" inline></iconify-icon></div>
                    <div class="module-card__title">{{ t.modules.crm_title }}</div>
                    <div class="module-card__desc">{{ t.modules.crm_desc }}</div>
                </a>
                <a href="{{ prefix }}/features.html#documents" class="module-card">
                    <div class="module-card__icon"><iconify-icon icon="fluent:document-text-20-filled" inline></iconify-icon></div>
                    <div class="module-card__title">{{ t.modules.documents_title }}</div>
                    <div class="module-card__desc">{{ t.modules.documents_desc }}</div>
                </a>
            </div>
        </div>
    </section>

    <!-- Product walkthrough — visual proof -->
    <section class="section section--primary">
        <div class="container">
            <div class="flex flex-2" style="align-items: center;">
                <div>
                    <div class="title text-white" style="font-size: 1.8rem;">{{ t.walkthrough.title }}</div>
                    <p style="color: rgba(255,255,255,0.85); margin-bottom: 1.5rem;">{{ t.walkthrough.body }}</p>
                    <a href="{{ prefix }}/demo.html" class="btn btn--success btn--md"><iconify-icon icon="fluent:play-circle-20-filled" inline class="mr-05"></iconify-icon> {{ t.walkthrough.cta }}</a>
                </div>
                <!-- TODO: Replace with embedded video (Loom/YouTube) or animated GIF walkthrough -->
                <div class="screenshot-placeholder" style="min-height: 280px;">
                    <div style="text-align: center;">
                        <iconify-icon icon="fluent:video-20-filled" inline style="font-size: 2rem; margin-bottom: 0.5rem; display: block;"></iconify-icon>
                        <span>{{ t.walkthrough.placeholder_text }}</span><br>
                        <small style="opacity: 0.5;">{{ t.walkthrough.placeholder_hint }}</small>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonial / Case study — your own story -->
    <section class="section">
        <div class="container">
            <div class="text-center mb-4">
                <div class="subtitle text-primary">{{ t.testimonial.subtitle }}</div>
                <div class="title text-charcoal">{{ t.testimonial.title }}</div>
            </div>

            <div class="flex flex-2" style="align-items: center; gap: 3rem;">
                <!-- TODO: Replace with photo of you/team + real quote -->
                <div class="screenshot-placeholder screenshot-placeholder--light" style="min-height: 300px; flex: 0 0 300px;">
                    <div style="text-align: center;">
                        <iconify-icon icon="fluent:person-circle-20-filled" inline style="font-size: 3rem; margin-bottom: 0.5rem; display: block;"></iconify-icon>
                        <span>{{ t.testimonial.placeholder_photo }}</span>
                    </div>
                </div>
                <div>
                    <blockquote style="font-size: 1.2rem; font-style: italic; color: var(--charcoal); line-height: 1.7; margin: 0 0 1.5rem; border-left: 4px solid var(--primary); padding-left: 1.5rem;">
                        "{{ t.testimonial.quote }}"
                    </blockquote>
                    <div>
                        <strong style="color: var(--charcoal);">{{ t.testimonial.name }}</strong><br>
                        <span class="text-gray">{{ t.testimonial.role }}</span>
                    </div>
                </div>
            </div>

            <!-- Additional case studies placeholder -->
            <div class="flex mt-4" style="gap: 1.5rem;">
                <div class="card p-2 bg-gradient-white" style="flex: 1;">
                    <div style="color: var(--primary); margin-bottom: 0.5rem;"><iconify-icon icon="fluent:text-quote-20-filled" inline></iconify-icon></div>
                    <p class="text-gray" style="font-style: italic; margin-bottom: 1rem;">"{{ t.testimonial.future1_quote }}"</p>
                    <div>
                        <strong class="text-charcoal">{{ t.testimonial.future1_name }}</strong><br>
                        <small class="text-gray">{{ t.testimonial.future1_role }}</small>
                    </div>
                </div>
                <div class="card p-2 bg-gradient-white" style="flex: 1;">
                    <div style="color: var(--primary); margin-bottom: 0.5rem;"><iconify-icon icon="fluent:text-quote-20-filled" inline></iconify-icon></div>
                    <p class="text-gray" style="font-style: italic; margin-bottom: 1rem;">"{{ t.testimonial.future2_quote }}"</p>
                    <div>
                        <strong class="text-charcoal">{{ t.testimonial.future2_name }}</strong><br>
                        <small class="text-gray">{{ t.testimonial.future2_role }}</small>
                    </div>
                </div>
                <div class="card p-2 bg-gradient-white" style="flex: 1;">
                    <div style="color: var(--primary); margin-bottom: 0.5rem;"><iconify-icon icon="fluent:text-quote-20-filled" inline></iconify-icon></div>
                    <p class="text-gray" style="font-style: italic; margin-bottom: 1rem;">"{{ t.testimonial.future3_quote }}"</p>
                    <div>
                        <strong class="text-charcoal">{{ t.testimonial.future3_name }}</strong><br>
                        <small class="text-gray">{{ t.testimonial.future3_role }}</small>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Comparison — what you're replacing -->
    <section class="section section--light">
        <div class="container">
            <div class="text-center mb-4">
                <div class="title text-charcoal">{{ t.comparison.title }}</div>
                <div class="body text-gray">{{ t.comparison.body }}</div>
            </div>

            <div class="flex flex-2" style="gap: 3rem;">
                <div class="card p-2" style="background: #fff;">
                    <div class="font-bold" style="color: var(--red); margin-bottom: 1rem;"><iconify-icon icon="fluent:dismiss-circle-20-filled" inline class="mr-05"></iconify-icon> {{ t.comparison.without_title }}</div>
                    <ul class="feature-list list-red">
                        {% for item in t.comparison.without_items %}
                        <li><iconify-icon icon="fluent:dismiss-20-filled" inline></iconify-icon> {{ item }}</li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="card p-2" style="background: #fff;">
                    <div class="font-bold" style="color: var(--success); margin-bottom: 1rem;"><iconify-icon icon="fluent:checkmark-circle-20-filled" inline class="mr-05"></iconify-icon> {{ t.comparison.with_title }}</div>
                    <ul class="feature-list list-success">
                        {% for item in t.comparison.with_items %}
                        <li><iconify-icon icon="fluent:checkmark-20-filled" inline></iconify-icon> {{ item }}</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Integration / ecosystem -->
    <section class="section">
        <div class="container">
            <div class="text-center mb-4">
                <div class="subtitle text-primary">{{ t.integrations.subtitle }}</div>
                <div class="title text-charcoal">{{ t.integrations.title }}</div>
            </div>

            <!-- TODO: Replace with actual integration logos -->
            <div class="flex" style="justify-content: center; align-items: center; gap: 3rem; flex-wrap: wrap; opacity: 0.5;">
                <div class="text-center text-gray" style="padding: 1.5rem;">
                    <iconify-icon icon="fa6-brands:google" inline style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></iconify-icon>
                    {{ t.integrations.google }}
                </div>
                <div class="text-center text-gray" style="padding: 1.5rem;">
                    <iconify-icon icon="fa6-brands:slack" inline style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></iconify-icon>
                    {{ t.integrations.slack }}
                </div>
                <div class="text-center text-gray" style="padding: 1.5rem;">
                    <iconify-icon icon="fluent:building-bank-20-filled" inline style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></iconify-icon>
                    {{ t.integrations.bank }}
                </div>
                <div class="text-center text-gray" style="padding: 1.5rem;">
                    <iconify-icon icon="fluent:receipt-20-filled" inline style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></iconify-icon>
                    {{ t.integrations.efaktura }}
                </div>
                <div class="text-center text-gray" style="padding: 1.5rem;">
                    <iconify-icon icon="fluent:mail-20-filled" inline style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></iconify-icon>
                    {{ t.integrations.email }}
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="section">
        <div class="container">
            <div class="platform-cta">
                <div class="title">{{ t.cta.title }}</div>
                <div class="body">{{ t.cta.body }}</div>
                <div class="hero-actions">
                    <a href="{{ prefix }}/demo.html" class="btn btn--success btn--md"><iconify-icon icon="fluent:calendar-checkmark-20-filled" inline class="mr-05"></iconify-icon> {{ t.cta.cta_demo }}</a>
                    <a href="{{ prefix }}/pricing.html" class="btn btn--ghost btn--md">{{ t.cta.cta_pricing }}</a>
                </div>
                <div class="trust-row" style="margin-top: 1.5rem;">
                    <div class="trust-item" style="color: rgba(255,255,255,0.7);"><iconify-icon icon="fluent:checkmark-circle-20-filled" inline style="color: rgba(255,255,255,0.5);"></iconify-icon> {{ t.cta.trust1 }}</div>
                    <div class="trust-item" style="color: rgba(255,255,255,0.7);"><iconify-icon icon="fluent:checkmark-circle-20-filled" inline style="color: rgba(255,255,255,0.5);"></iconify-icon> {{ t.cta.trust2 }}</div>
                    <div class="trust-item" style="color: rgba(255,255,255,0.7);"><iconify-icon icon="fluent:checkmark-circle-20-filled" inline style="color: rgba(255,255,255,0.5);"></iconify-icon> {{ t.cta.trust3 }}</div>
                </div>
            </div>
        </div>
    </section>
