    <section class="platform-hero" style="min-height: 60vh; display: flex; align-items: center;">
        <div class="container">
            <div style="font-size: 3rem; margin-bottom: 1rem;">&#10003;</div>
            <h1 class="title">{{ t.title }}</h1>
            <p class="body">{{ t.body }}</p>
            <div class="hero-actions">
                <a href="{{ t.platformLink }}" class="btn btn--ghost btn--md">{{ t.btn_platform }}</a>
                <a href="{{ t.featuresLink }}" class="btn btn--success btn--md">{{ t.btn_features }}</a>
            </div>
        </div>
    </section>
