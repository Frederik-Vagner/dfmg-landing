    <!-- Hero -->
    <section class="platform-hero" style="padding-bottom: 3rem;">
        <div class="container">
            <div class="subtitle" style="color: rgba(255,255,255,0.6);">{{ t.hero.subtitle }}</div>
            <h1 class="title">{{ t.hero.title }}</h1>
            <p class="body">{{ t.hero.body }}</p>
        </div>
    </section>

    <!-- Tier cards -->
    <section class="section">
        <div class="container">
            <div class="pricing-tiers">
                {% for tier in t.tiers %}
                <div class="card--tier{% if tier.featured %} card--tier--featured{% endif %}">
                    {% if tier.badge %}
                    <div class="badge-inline badge-inline--primary card--tier__badge">{{ tier.badge }}</div>
                    {% endif %}
                    <div class="card--tier__name">{{ tier.name }}</div>
                    <div class="card--tier__desc">{{ tier.desc }}</div>
                    <div class="card--tier__price">{{ tier.price }}</div>
                    <div class="card--tier__divider"></div>
                    <ul class="card--tier__features">
                        {% for feature in tier.features %}
                        <li><iconify-icon icon="fluent:checkmark-20-filled" inline></iconify-icon> {{ feature }}</li>
                        {% endfor %}
                    </ul>
                    <a href="{{ tier.ctaHref }}" class="{{ tier.ctaClass }}">{{ tier.ctaText }}</a>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Comparison table -->
    <section class="section section--light">
        <div class="container">
            <div class="text-center mb-4">
                <div class="title text-charcoal">{{ t.comparison.title }}</div>
                <div class="body text-gray">{{ t.comparison.body }}</div>
            </div>

            <table class="comparison-table">
                <thead>
                    <tr>
                        <th>{{ t.comparison.colModule }}</th>
                        <th>{{ t.comparison.colStarter }}</th>
                        <th>{{ t.comparison.colProfessional }}</th>
                        <th>{{ t.comparison.colEnterprise }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for category in t.comparison.categories %}
                    <tr class="category-row"><td colspan="4">{{ category.name }}</td></tr>
                    {% for row in category.rows %}
                    <tr>
                        <td>{{ row.module }}</td>
                        <td class="{% if row.starter %}check{% else %}dash{% endif %}">{% if row.starter %}<iconify-icon icon="fluent:checkmark-20-filled" inline></iconify-icon>{% else %}&#8212;{% endif %}</td>
                        <td class="{% if row.professional %}check{% else %}dash{% endif %}">{% if row.professional %}<iconify-icon icon="fluent:checkmark-20-filled" inline></iconify-icon>{% else %}&#8212;{% endif %}</td>
                        <td class="{% if row.enterprise %}check{% else %}dash{% endif %}">{% if row.enterprise %}<iconify-icon icon="fluent:checkmark-20-filled" inline></iconify-icon>{% else %}&#8212;{% endif %}</td>
                    </tr>
                    {% endfor %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    <!-- FAQ -->
    <section class="section">
        <div class="container">
            <div class="text-center mb-4">
                <div class="title text-charcoal">{{ t.faq.title }}</div>
            </div>

            <div class="faq-list">
                {% for item in t.faq.items %}
                <div class="faq-item">
                    <div class="faq-question" data-action="toggle-platform-faq">
                        <h4>{{ item.question }}</h4>
                        <iconify-icon icon="fluent:chevron-down-20-filled" inline></iconify-icon>
                    </div>
                    <div class="faq-answer">
                        <p>{{ item.answer }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Trust signals -->
    <section class="section" style="padding-top: 0;">
        <div class="container">
            <div class="trust-row" style="justify-content: center;">
                {% for item in t.trust.items %}
                <div class="trust-item"><iconify-icon icon="fluent:checkmark-circle-20-filled" inline></iconify-icon> {{ item }}</div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Testimonial on pricing page -->
    <section class="section section--light">
        <div class="container">
            <div class="text-center" style="max-width: 700px; margin: 0 auto;">
                <!-- TODO: Replace with real testimonial about value/pricing -->
                <div style="color: var(--primary); font-size: 2rem; margin-bottom: 1rem;"><iconify-icon icon="fluent:text-quote-20-filled" inline></iconify-icon></div>
                <p style="font-size: 1.15rem; font-style: italic; color: var(--charcoal); line-height: 1.7; margin-bottom: 1.5rem;">
                    "{{ t.testimonial.quote }}"
                </p>
                <strong class="text-charcoal">{{ t.testimonial.name }}</strong><br>
                <small class="text-gray">{{ t.testimonial.company }}</small>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section">
        <div class="container">
            <div class="platform-cta">
                <div class="title">{{ t.cta.title }}</div>
                <div class="body">{{ t.cta.body }}</div>
                <div class="hero-actions">
                    <a href="{{ prefix }}/demo.html" class="btn btn--success btn--md"><iconify-icon icon="fluent:calendar-checkmark-20-filled" inline class="mr-05"></iconify-icon> {{ t.cta.cta_demo }}</a>
                    <a href="{{ prefix }}/contact.html" class="btn btn--ghost btn--md">{{ t.cta.cta_sales }}</a>
                </div>
            </div>
        </div>
    </section>
