                            <strong style="color: var(--charcoal); font-size: 1.1rem;">{{ t.multiFloor.visual_title }}</strong><br><br>
                            <div style="text-align: left; max-width: 300px; margin: 0 auto; color: var(--gray); font-size: 0.9rem; line-height: 2;">
                                {% for item in t.multiFloor.visual_items %}
                                <iconify-icon icon="{{ item.icon }}" inline class="placeholder-list-icon"></iconify-icon> {{ item.text }}<br>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Annotations & export -->
    <section class="section section--light" id="annotations">
        <div class="container">
            <div class="feature-row feature-row--reverse">
                <div class="feature-row__content">
                    <div class="feature-row__subtitle">{{ t.annotations.subtitle }}</div>
                    <h2 class="feature-row__title">{{ t.annotations.title }}</h2>
                    <p class="feature-row__body">{{ t.annotations.body1 }}</p>
                    <p class="feature-row__body">{{ t.annotations.body2 }}</p>
                    <div class="feature-row__modules">
                        {% for badge in t.annotations.badges %}
                        <span class="badge-inline badge-inline--sm bg-light text-charcoal">{{ badge }}</span>
                        {% endfor %}
                    </div>
                </div>
                <div class="feature-row__visual">
                    <div class="screenshot-placeholder screenshot-placeholder--light">
                        <div style="text-align: center;">
                            <iconify-icon icon="fluent:pen-20-filled" inline class="placeholder-icon"></iconify-icon>
                            <strong style="color: var(--charcoal); font-size: 1.1rem;">{{ t.annotations.visual_title }}</strong><br><br>
                            <div style="text-align: left; max-width: 300px; margin: 0 auto; color: var(--gray); font-size: 0.9rem; line-height: 2;">
                                {% for item in t.annotations.visual_items %}
                                <iconify-icon icon="{{ item.icon }}" inline class="placeholder-list-icon"></iconify-icon> {{ item.text }}<br>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Key benefits -->
    <section class="section">
        <div class="container">
            <div class="value-grid">
                {% for benefit in t.benefits %}
                <div class="value-card">
                    <div class="value-card__icon">
                        <iconify-icon icon="{{ benefit.icon }}" inline></iconify-icon>
                    </div>
                    <div class="value-card__title">{{ benefit.title }}</div>
                    <div class="value-card__desc">{{ benefit.desc }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section">
        <div class="container">
            <div class="platform-cta">
                <div class="title">{{ t.cta.title }}</div>
                <div class="body">{{ t.cta.body }}</div>
                <div class="hero-actions">
                    <a href="{{ prefix }}/demo.html" class="btn btn--success btn--md">{{ t.cta.cta_demo }}</a>
                    <a href="{{ prefix }}/features.html" class="btn btn--ghost btn--md">{{ t.cta.cta_features }}</a>
                </div>
            </div>
        </div>
    </section>
