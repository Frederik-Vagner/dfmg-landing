                            <strong style="color: var(--charcoal); font-size: 1.1rem;">{{ t.routes.visual_title }}</strong><br><br>
                            <div style="text-align: left; max-width: 300px; margin: 0 auto; color: var(--gray); font-size: 0.9rem; line-height: 2;">
                                {% for step in t.routes.steps %}
                                <span style="color: var(--primary); font-weight: 600;">{{ loop.index }}.</span> {{ step }}<br>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Multi-floor -->
    <section class="section" id="multi-floor">
        <div class="container">
            <div class="feature-row">
                <div class="feature-row__content">
                    <div class="feature-row__subtitle">{{ t.multiFloor.subtitle }}</div>
                    <h2 class="feature-row__title">{{ t.multiFloor.title }}</h2>
                    <p class="feature-row__body">{{ t.multiFloor.body1 }}</p>
