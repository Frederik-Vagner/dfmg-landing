    <!-- Hero -->
    <section class="platform-hero" style="padding-bottom: 3rem;">
        <div class="container">
            <div class="subtitle" style="color: rgba(255,255,255,0.6);">{{ t.hero.subtitle }}</div>
            <h1 class="title">{{ t.hero.title }}</h1>
            <p class="body">{{ t.hero.body }}</p>
            <div class="hero-actions">
                <a href="{{ prefix }}/demo.html" class="btn btn--success btn--md">{{ t.hero.cta_demo }}</a>
                <a href="#supported-functions" class="btn btn--ghost btn--md">{{ t.hero.cta_functions }}</a>
            </div>
        </div>
    </section>

    <!-- Trust badge -->
    <section class="section" style="padding-top: 2.5rem; padding-bottom: 0;">
        <div class="container">
            <div class="trust-row">
                {% for item in t.trust %}
                <div class="trust-item"><iconify-icon icon="fluent:checkmark-circle-20-filled" inline></iconify-icon> {{ item }}</div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- What this means for you -->
    <section class="section" id="overview">
        <div class="container">
            <div class="feature-row">
                <div class="feature-row__content">
                    <div class="feature-row__subtitle">{{ t.overview.subtitle }}</div>
                    <h2 class="feature-row__title">{{ t.overview.title }}</h2>
                    <p class="feature-row__body">{{ t.overview.body1 }}</p>
                    <p class="feature-row__body">{{ t.overview.body2 }}</p>
                </div>
                <div class="feature-row__visual">
                    <div class="screenshot-placeholder screenshot-placeholder--light">
                        <div style="text-align: center;">
                            <iconify-icon icon="fluent:building-bank-20-filled" inline class="placeholder-icon"></iconify-icon>
                            <strong style="color: var(--charcoal); font-size: 1.1rem;">{{ t.overview.visual_title }}</strong><br><br>
                            <div style="text-align: left; max-width: 300px; margin: 0 auto; color: var(--gray); font-size: 0.9rem; line-height: 2;">
                                {% for step in t.overview.steps %}
                                <span style="color: var(--primary); font-weight: 600;">{{ loop.index }}.</span> {{ step }}<br>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Key benefits -->
    <section class="section section--light">
        <div class="container">
            <div class="value-grid">
                {% for benefit in t.benefits %}
                <div class="card--feature card--feature--center">
                    <div class="card--feature__icon">
                        <iconify-icon icon="{{ benefit.icon }}" inline></iconify-icon>
                    </div>
                    <div class="card--feature__title">{{ benefit.title }}</div>
                    <div class="card--feature__desc">{{ benefit.desc }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Supported functions table -->
    <section class="section" id="supported-functions">
        <div class="container">
            <div class="feature-row">
                <div class="feature-row__content">
                    <div class="feature-row__subtitle">{{ t.functions.subtitle }}</div>
                    <h2 class="feature-row__title">{{ t.functions.title }}</h2>
                    <p class="feature-row__body">{{ t.functions.body1 }}</p>
                    <p class="feature-row__body">{{ t.functions.body2 }}</p>
                    <div class="feature-row__modules">
                        {% for badge in t.functions.badges %}
                        <span class="badge-inline badge-inline--sm badge-inline--light">{{ badge }}</span>
                        {% endfor %}
                    </div>
                </div>
                <div class="feature-row__visual">
                    <div class="bc-table-wrapper">
                        <table class="bc-table">
                            <thead>
                                <tr>
                                    <th colspan="2">{{ t.functions.table_title }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for category in t.functions.categories %}
                                <tr class="bc-table__category">
                                    <td colspan="2"><iconify-icon icon="{{ category.icon }}" inline></iconify-icon> {{ category.name }}</td>
                                </tr>
                                {% for item in category.items %}
                                <tr><td><iconify-icon icon="fluent:checkmark-20-filled" inline class="bc-table__check"></iconify-icon></td><td>{{ item }}</td></tr>
                                {% endfor %}
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- What is Bank Connect -->
    <section class="section section--light">
        <div class="container">
            <div class="callout-box">
                <div class="callout-box__title"><iconify-icon icon="fluent:info-20-filled" inline></iconify-icon> {{ t.callout.title }}</div>
                <div class="callout-box__body">{{ t.callout.body }}</div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section">
        <div class="container">
            <div class="platform-cta">
                <div class="title">{{ t.cta.title }}</div>
                <div class="body">{{ t.cta.body }}</div>
                <div class="hero-actions">
                    <a href="{{ prefix }}/demo.html" class="btn btn--success btn--md">{{ t.cta.cta_demo }}</a>
                    <a href="{{ prefix }}/features.html" class="btn btn--ghost btn--md">{{ t.cta.cta_features }}</a>
                </div>
            </div>
        </div>
    </section>
